# Site identity
APP_USERNAME=your_username
APP_DOMAIN=your_domain.com

# Required: Last.fm
LASTFM_API_KEY=your_lastfm_api_key
LASTFM_USER=your_lastfm_username

# Scheduler
FETCH_INTERVAL_HOURS=6

# Optional: Kashidashi (reading tracker)
KASHIDASHI_BASE_URL=

# Optional: iOS Shortcut webhook
WEBHOOK_SECRET=

# Optional: Oura Ring
OURA_PERSONAL_ACCESS_TOKEN=

# Optional: intervals.icu
INTERVALS_API_KEY=
INTERVALS_ATHLETE_ID=

# Optional: Strava (OAuth2)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Optional: Google (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
