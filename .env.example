# Site identity
APP_USERNAME=your_username
APP_DOMAIN=your_domain.com

# Required: Last.fm
LASTFM_API_KEY=your_lastfm_api_key
LASTFM_USER=your_lastfm_username

# Scheduler
FETCH_INTERVAL_HOURS=6

# Optional: Kashidashi (reading tracker)
KASHIDASHI_BASE_URL=

# Optional: iOS Shortcut webhook
WEBHOOK_SECRET=

# Optional: Oura Ring
OURA_PERSONAL_ACCESS_TOKEN=

# Optional: intervals.icu
INTERVALS_API_KEY=
INTERVALS_ATHLETE_ID=

# Optional: Strava (OAuth2)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Optional: Google (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Google Calendar IDs
# gcal_holiday: メインカレンダー（例: your_email@gmail.com または "primary"）
GCAL_HOLIDAY_CALENDAR_ID=primary
# gcal_live: ライブ専用カレンダーのID（Google CalendarのカレンダーIDをコピー）
GCAL_LIVE_CALENDAR_ID=

# Optional: sync-gateway (Filmarks, 読書メーター)
SYNC_GATEWAY_BASE_URL=

# Optional: GitHub
GITHUB_TOKEN=
GITHUB_USER=

# Optional: Anthropic Admin API (Claude Code usage)
ANTHROPIC_ADMIN_API_KEY=

# Optional: OpenAI Admin API
OPENAI_ADMIN_API_KEY=
